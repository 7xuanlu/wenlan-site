{
  "name": "wenlan-site",
  "version": "1.0.0",
  "description": "Public website and SEO/GEO surface for Wenlan, an LLM wiki for AI work.",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "postbuild": "node scripts/indexnow-ping.mjs",
    "seo:weekly": "node scripts/seo-weekly-pipeline.mjs",
    "seo:weekly:run": "node scripts/seo-weekly-pipeline.mjs",
    "seo:weekly:sample": "node scripts/seo-weekly-pipeline.mjs --input-dir scripts/fixtures/seo-weekly --allow-fixture-input true --date 2026-06-07 --output /tmp/wenlan-weekly-seo-sample.md",
    "seo:gsc:fetch": "node scripts/seo-gsc-fetch.mjs",
    "seo:vercel:fetch": "node scripts/seo-vercel-fetch.mjs",
    "seo:goal:check": "node scripts/seo-goal-check.mjs",
    "seo:ai-visibility": "node scripts/seo-ai-visibility-worksheet.mjs",
    "seo:technical:built": "node scripts/seo-built-technical-check.mjs",
    "seo:technical:deployed": "node scripts/seo-deployed-technical-check.mjs",
    "test:goal": "node --test scripts/seo-goal-check.test.mjs",
    "test:i18n": "node --import tsx --test scripts/i18n-contract.test.mjs",
    "i18n:technical:built": "node scripts/i18n-built-check.mjs",
    "test:seo": "node --test scripts/brand-contract.test.mjs scripts/app-contract.test.mjs scripts/seo-goal-check.test.mjs scripts/seo-weekly.test.mjs",
    "start": "next start",
    "lint": "pnpm exec tsc --noEmit --incremental false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/7xuanlu/wenlan-site.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/7xuanlu/wenlan-site/issues"
  },
  "homepage": "https://wenlan.app",
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "geist": "^1.7.0",
    "next": "^16.2.1",
    "next-intl": "^4.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
